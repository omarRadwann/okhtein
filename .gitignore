# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# static export output (deployed to the gh-pages branch, not source)
/out/

# large unused Tripo source GLBs — only the *.optimized.glb files are shipped
/public/models/tripo/*_v01.glb

# local reference / knowledge pack (not part of the app)
/_pack_v5/

# scratch: AI video generation candidates (not part of the app/deploy)
/.vidcand/

# dev-only self-verification screenshots (scripts/_shot.mjs + all _*check/_*probe runs)
/.shots/
/.shots-*/
/.imgcheck/
bash.exe.stackdump

# CI workflow needs the gh "workflow" OAuth scope to push; deploying via the gh-pages branch instead.
/.github/
